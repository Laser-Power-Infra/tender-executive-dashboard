// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum TenderUpdateStatus {
  OPEN
  CLOSED
}

enum NextAction {
  UPDATE_FROM_AB_LETTER
  BG_REFUND_LETTER_TO_BE_SENT
  FOLLOW_UP_FOR_FINANCIAL_STATUS
  REVERSE_AUCTION_PENDING
}

enum TenderType {
  GEM
  NON_GEM
}

model User {
  id           String        @id @default(uuid())
  name         String?
  email        String        @unique
  passwordHash String?
  role         String        @default("user")
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  activityLogs ActivityLog[]

  @@map("users")
}

model ActivityLog {
  id          String   @id @default(uuid())
  userId      String?
  userName    String?
  userEmail   String?
  referenceNo String?
  action      String // "CREATE" | "UPDATE" | "DELETE"
  tableName   String // e.g. "Tender", "GemTender", "ColumnMapping"
  recordId    String? // ID of the affected record
  details     String? // JSON — what changed / description
  createdAt   DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([createdAt])
  @@map("activity_logs")
}

model Tender {
  id           String   @id @default(uuid())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  slNo         Int
  docketNo     String
  tenderFor    String
  typeOfTender String

  tenderNoNitNo            String             @unique @map("Tender No / NIT No with Date")
  nameOfWorkDescription    String?            @map("Name of Work / Item Description")
  totalQuantityMeter       Float?             @map("Total Quantity in Meter")
  nameOfTheClient          String             @map("Name of the Client")
  lastDateOfSubmission     DateTime?          @map("Last Date of Submission")
  tenderOpeningDate        DateTime?          @map("Tender Opening Date")
  costOfTenderFeeRs        Float?             @map("Cost of Tender / Tender Fee (In Rs)")
  emdAmountRs              Float?             @map("EMD Amount (In Rs)")
  estimatedCostRs          Float?             @map("Estimated Cost (In Rs)")
  bidValidityDays          Int?               @map("Bid Validity (in Days)")
  contractPeriodDays       Int?               @map("Contract Period in Days")
  managementDecision       String             @map("Management Decision")
  participated             Boolean            @map("Participated")
  tenderPrepareBy          String             @map("Tender Prepare By")
  currentStatus            String             @map("Current Status")
  tenderSubmittedDate      DateTime?          @map("Tender Submitted Date")
  reverseAuctionApplicable Boolean?           @map("Reverse Auction Applicable")
  reverseAuctionDate       DateTime?          @map("Reverse Auction Date")
  emdPaymentMode           String?            @map("EMD Payment Through BG / NEFT")
  bgNoUtrNo                String?            @map("BG No / UTR No")
  emdValidity              DateTime?          @map("EMD Validity")
  loiPoNoAndDate           String?            @map("LOI / PO No & Date")
  remarks                  String?            @map("Remarks")
  bidValidityExpired       Boolean            @map("Bid Validity Expired")
  diffPercentFromL1        Float?             @map("Diff % from L1")
  diffPercentFromL2        Float?             @map("Diff % from L2")
  reason                   String?            @map("Reason")
  finalRemarks             String?            @map("Final Remarks")
  attachmentUrl            String?            @map("attachmentUrl")
  tenderUpdateStatus       TenderUpdateStatus @default(OPEN)
  nextAction               NextAction?
  diffL1ManuallyEdited     Boolean            @default(false)
  diffL2ManuallyEdited     Boolean            @default(false)

  cva          String?
  quotationNo  String?
  rawMaterials String?
}

model SmartsheetTender {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  enquiryDate     String?
  partyName       String?
  docketNumber    String? @unique
  utility         String?
  quotationNumber String?
  quotationDate   String?
  accountHolder   String?
  tenderPurchase  String?

  attachmentUrl                 String?
  proposedErpItemName           String?
  proposedQty                   String?
  priceBasis                    String?
  aluminiumPrice                Float?
  aluminiumAlloyPrice           Float?
  copperTapePrice               Float?
  extrudedSemiconductivePrice   Float?
  htXlpePrice                   Float?
  pvcTypeSt2Price               Float?
  galvanisedSteelFlatStripPrice Float?
  fillerPrice                   Float?

  lastSyncedAt DateTime @default(now())
}

model SupplyHistory {
  id        String   @id @default(uuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fy             String?
  saleBillNumber String?
  saleBillDate   String?
  partyName      String?
  itemCode       String?
  itemName       String?
  lrNo           String?
  truckNo        String?
  partyRefNo     String?
  partyRefDate   String?
  contractVrNo   String?
  rate           Float?
  invoiceQty     Float?
  invoiceAmt     Float?

  documentUrls  String?
  attachmentUrl String?

  lastSyncedAt DateTime @default(now())

  @@unique([saleBillNumber, itemCode])
}

enum Decision {
  YES
  NO
  NOT_DECIDED

  @@map("decision")
}

// ---------- FILES ----------
model File {
  id         Int     @id @default(autoincrement())
  fileName   String
  filePath   String?
  fileType   String?
  fileSize   Int?
  uploadedBy String?
  status     String?

  totalCount    Int? @default(0)
  excludedCount Int? @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  gemTenders       GemTender[]
  nonGemTenders    NonGemTender[]
  tenderMergedList TenderMerged[]

  @@map("files")
}

// ---------- GEM TENDER ----------
model GemTender {
  id Int @id @default(autoincrement())

  fileId Int
  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  referenceNo String  @unique
  tenderBrief String?

  value              String?
  deadline           DateTime?
  location           String?
  organization       String?
  documentFees       String?
  emd                String?
  msmeExemption      String?
  startupExemption   String?
  quantity           String?
  bidOpeningDateTime String?
  bidOfferValidity   String?

  ministryStateName String?
  departmentName    String?
  officeName        String?

  size String?

  minimumAverageAnnualTurnover String?
  yearsOfPastExperience        String?
  oemAverageTurnover           String?
  contractPeriod               String?

  financialDocumentPriceBreakupRequired String?
  similarCategory                       String?
  pastExperienceSimilarServicesRequired String?

  documentRequiredFromSeller String?
  pastPerformance            String?
  bidToRaEnabled             String?
  raQualificationRule        String?

  boqTitle   String?
  bidDetails String?

  comprehensiveMaintenanceChargesRequired String?
  typeOfBid                               String?

  technicalClarificationTimeAllowed String?
  inspectionRequired                String?

  estimatedBidValue String?
  evaluationMethod  String?
  advisoryBank      String?

  ePbgPercentage     String?
  ePbgDurationMonths String?

  msePurchasePreference String?
  miiPurchasePreference String?

  consigneesReportingOfficer String?
  mediationClause            String?
  arbitrationClause          String?

  checklist String?

  t247Id       String?
  scrapedDate  String?
  source       String?
  assignedTo   String?
  markedStatus String?
  sheetStatus  String?
  ready        String?
  searchKey    String?
  downloadLink String?
  currency     String?

  excludedCategory String?

  aiRelevanceValid  Boolean?
  aiRelevanceReason String?

  tenderFileUrl String?

  parseStatus String? @map("parse_status")
  parseError  String? @map("parse_error")

  resultAutomationStatus String? @map("result_automation_status")
  resultAutomationError  String? @map("result_automation_error")

  itemCategory  String?
  totalQuantity String?

  bidStatus              String?
  differenceBetweenRank1 String?
  nameOfRank1            String?
  valueOfRank1           String?

  differenceBetweenRank2 String?
  nameOfRank2            String?
  valueOfRank2           String?

  evaluationTableData String?

  docketNo      String?
  attachmentUrl String?
  remarks       String?

  app Decision @default(NOT_DECIDED)
  aps Decision @default(NOT_DECIDED)
  apm Decision @default(NOT_DECIDED)

  tenderStatusId Int?
  tenderStatus   TenderStatusTable? @relation("GemTenderStatus", fields: [tenderStatusId], references: [id], onDelete: SetNull)
  state          String?
  website        String?
  locationCount  Int?

  utilityMappingId Int?
  utilityMapping   UtilityMapping? @relation(fields: [utilityMappingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extraFields        TenderExtraField[]
  tenderAssociations TenderAssociation[]
  reportings         Reporting[]
  evaluations        Evaluation[]

  @@index([fileId])
  @@index([utilityMappingId])
  @@map("gem_tenders")
}

// ---------- NON GEM ----------
model NonGemTender {
  id Int @id @default(autoincrement())

  fileId Int
  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  referenceNo String  @unique
  tenderBrief String?

  estimatedBidValue String?
  deadline          DateTime?
  location          String?
  organization      String?

  documentFees String?
  emd          String?

  msmeExemption    String?
  startupExemption String?

  quantity String?

  checklist String?

  t247Id       String?
  scrapedDate  String?
  source       String?
  assignedTo   String?
  markedStatus String?
  sheetStatus  String?
  ready        String?
  searchKey    String?
  downloadLink String?
  currency     String?

  excludedCategory String?

  aiRelevanceValid  Boolean?
  aiRelevanceReason String?

  tenderFileUrl String?

  docketNo      String?
  attachmentUrl String?
  remarks       String?

  app Decision @default(NOT_DECIDED)
  aps Decision @default(NOT_DECIDED)
  apm Decision @default(NOT_DECIDED)

  tenderStatusId Int?
  tenderStatus   TenderStatusTable? @relation("NonGemTenderStatus", fields: [tenderStatusId], references: [id], onDelete: SetNull)
  state          String?
  website        String?
  locationCount  Int?

  utilityMappingId Int?
  utilityMapping   UtilityMapping? @relation(fields: [utilityMappingId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  extraFields        TenderExtraField[]
  tenderAssociations TenderAssociation[]

  @@index([fileId])
  @@index([utilityMappingId])
  @@map("non_gem_tenders")
}

model TenderExtraField {
  id Int @id @default(autoincrement())

  gemTenderId Int?
  gemTender   GemTender? @relation(fields: [gemTenderId], references: [id], onDelete: Cascade)

  nonGemTenderId Int?
  nonGemTender   NonGemTender? @relation(fields: [nonGemTenderId], references: [id], onDelete: Cascade)

  tenderMergedId Int?
  tenderMerged   TenderMerged? @relation(fields: [tenderMergedId], references: [id], onDelete: Cascade)

  fieldName  String
  fieldValue String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gemTenderId])
  @@index([nonGemTenderId])
  @@index([tenderMergedId])
  @@map("tender_extra_fields")
}

model ColumnMapping {
  id          Int      @id @default(autoincrement())
  excelHeader String
  dbField     String
  displayName String?
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([excelHeader, dbField])
  @@index([dbField])
  @@map("column_mappings")
}

model ColumnGroup {
  id        Int      @id @default(autoincrement())
  label     String
  separator String   @default(" @ ")
  fields    String
  status    String   @default("active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("column_groups")
}

// ---------- COLUMN INDEX ----------
model ColumnIndex {
  id           Int      @id @default(autoincrement())
  columnName   String
  displayOrder Int
  displayName  String?
  visible      Boolean  @default(true)
  width        Int?
  frozen       Boolean  @default(false)
  status       String   @default("active")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([columnName])
  @@map("column_indices")
}

model ExlusionKeywords {
  id Int @id @default(autoincrement())

  category String  @unique
  keywords String? @default("cable")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ---------- ASSOCIATION ----------
model Association {
  id        Int      @id @default(autoincrement())
  name      String
  email     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenderAssociations TenderAssociation[]

  @@map("associations")
}

model TenderAssociation {
  id Int @id @default(autoincrement())

  gemTenderId Int?
  gemTender   GemTender? @relation(fields: [gemTenderId], references: [id], onDelete: Cascade)

  nonGemTenderId Int?
  nonGemTender   NonGemTender? @relation(fields: [nonGemTenderId], references: [id], onDelete: Cascade)

  tenderMergedId Int?
  tenderMerged   TenderMerged? @relation(fields: [tenderMergedId], references: [id], onDelete: Cascade)

  associationId Int
  association   Association @relation(fields: [associationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([gemTenderId, associationId])
  @@unique([nonGemTenderId, associationId])
  @@unique([tenderMergedId, associationId])
  @@index([gemTenderId])
  @@index([nonGemTenderId])
  @@index([tenderMergedId])
  @@index([associationId])
  @@map("tender_associations")
}

// ---------- REPORTING ----------
model Reporting {
  id          Int        @id @default(autoincrement())
  gemTenderId Int?
  gemTender   GemTender? @relation(fields: [gemTenderId], references: [id], onDelete: Cascade)

  tenderMergedId Int?
  tenderMerged   TenderMerged? @relation(fields: [tenderMergedId], references: [id], onDelete: Cascade)

  officer  String
  address  String?
  quantity String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gemTenderId])
  @@index([tenderMergedId])
  @@map("reportings")
}

// ---------- TENDER STATUS TABLE ----------
model TenderStatusTable {
  id              Int      @id @default(autoincrement())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  state           String?
  website         String?
  type            String   @default("GEM")
  userId          String?
  password        String?
  mobileNo        String?
  profilePassword String?
  dscName         String?
  dscPassword     String?

  gemTenders       GemTender[]    @relation("GemTenderStatus")
  nonGemTenders    NonGemTender[] @relation("NonGemTenderStatus")
  tenderMergedList TenderMerged[]

  @@map("tender_status_table")
}

// ---------- EVALUATION ----------
model Evaluation {
  id          Int        @id @default(autoincrement())
  gemTenderId Int?
  gemTender   GemTender? @relation(fields: [gemTenderId], references: [id], onDelete: Cascade)

  tenderMergedId Int?
  tenderMerged   TenderMerged? @relation(fields: [tenderMergedId], references: [id], onDelete: Cascade)

  sellerName  String
  offeredItem String?
  totalPrice  String?
  rank        String?
  status      String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([gemTenderId])
  @@index([tenderMergedId])
  @@map("evaluations")
}

// ---------- AI FEEDBACK ----------
model AiFeedback {
  id             String   @id @default(uuid())
  tenderId       Int
  tenderType     String
  briefText      String
  originalAi     String
  correctedAi    String
  feedbackReason String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([tenderId, tenderType])
  @@map("ai_feedback")
}

// ---------- UTILITY MAPPING ----------
model UtilityMapping {
  id           Int      @id @default(autoincrement())
  organization String
  website      String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  gemTenders       GemTender[]
  nonGemTenders    NonGemTender[]
  tenderMergedList TenderMerged[]

  @@map("utility_mappings")
}

// ---------- TENDER MERGED ----------
model TenderMerged {
  id         Int        @id @default(autoincrement())
  tenderType TenderType
  originalId Int?

  referenceNo       String    @unique
  tenderBrief       String?
  deadline          DateTime?
  location          String?
  organization      String?
  documentFees      String?
  emd               String?
  msmeExemption     String?
  startupExemption  String?
  quantity          String?
  checklist         String?
  t247Id            String?
  scrapedDate       String?
  source            String?
  assignedTo        String?
  markedStatus      String?
  sheetStatus       String?
  ready             String?
  searchKey         String?
  downloadLink      String?
  currency          String?
  excludedCategory  String?
  aiRelevanceValid  Boolean?
  aiRelevanceReason String?
  tenderFileUrl     String?
  docketNo          String?
  attachmentUrl     String?
  remarks           String?
  app               Decision  @default(NOT_DECIDED)
  aps               Decision  @default(NOT_DECIDED)
  apm               Decision  @default(NOT_DECIDED)
  state             String?
  website           String?
  locationCount     Int?
  size              String?

  slNo                     Int?
  tenderFor                String?
  tenderOpeningDate        DateTime?
  bidValidityDays          Int?
  contractPeriodDays       Int?
  participated             Boolean?
  currentStatus            String?
  reverseAuctionApplicable Boolean?
  reverseAuctionDate       DateTime?
  emdPaymentMode           String?
  bgNoUtrNo                String?
  emdValidity              DateTime?
  loiPoNoAndDate           String?
  bidValidityExpired       Boolean?
  diffPercentFromL1        Float?
  diffPercentFromL2        Float?
  reason                   String?
  finalRemarks             String?
  tenderUpdateStatus       TenderUpdateStatus?
  nextAction               NextAction?
  diffL1ManuallyEdited     Boolean?
  diffL2ManuallyEdited     Boolean?
  cva                      String?
  quotationNo              String?
  rawMaterials             String?

  value                                   String?
  bidOpeningDateTime                      String?
  bidOfferValidity                        String?
  ministryStateName                       String?
  departmentName                          String?
  officeName                              String?
  minimumAverageAnnualTurnover            String?
  yearsOfPastExperience                   String?
  oemAverageTurnover                      String?
  contractPeriod                          String?
  financialDocumentPriceBreakupRequired   String?
  similarCategory                         String?
  pastExperienceSimilarServicesRequired   String?
  documentRequiredFromSeller              String?
  pastPerformance                         String?
  bidToRaEnabled                          String?
  raQualificationRule                     String?
  boqTitle                                String?
  bidDetails                              String?
  comprehensiveMaintenanceChargesRequired String?
  typeOfBid                               String?
  technicalClarificationTimeAllowed       String?
  inspectionRequired                      String?
  estimatedBidValue                       String?
  evaluationMethod                        String?
  advisoryBank                            String?
  ePbgPercentage                          String?
  ePbgDurationMonths                      String?
  msePurchasePreference                   String?
  miiPurchasePreference                   String?
  consigneesReportingOfficer              String?
  mediationClause                         String?
  arbitrationClause                       String?
  itemCategory                            String?
  totalQuantity                           String?
  bidStatus                               String?
  differenceBetweenRank1                  String?
  nameOfRank1                             String?
  valueOfRank1                            String?
  differenceBetweenRank2                  String?
  nameOfRank2                             String?
  valueOfRank2                            String?
  evaluationTableData                     String?
  parseStatus                             String?
  parseError                              String?
  resultAutomationStatus                  String?
  resultAutomationError                   String?

  fileId Int
  file   File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  tenderStatusId Int?
  tenderStatus   TenderStatusTable? @relation(fields: [tenderStatusId], references: [id], onDelete: SetNull)

  utilityMappingId Int?
  utilityMapping   UtilityMapping? @relation(fields: [utilityMappingId], references: [id])

  extraFields        TenderExtraField[]
  tenderAssociations TenderAssociation[]
  reportings         Reporting[]
  evaluations        Evaluation[]
  tenderFiles        TenderFile[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([fileId])
  @@index([tenderStatusId])
  @@index([utilityMappingId])
  @@map("tender_merged")
}

// ---------- TENDER FILES ----------
model TenderFile {
  id        Int      @id @default(autoincrement())
  name      String
  extension String
  url       String
  source    String
  tags      String[] @default([])

  tenderMergedId Int?
  tenderMerged   TenderMerged? @relation(fields: [tenderMergedId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenderMergedId])
  @@map("tender_files")
}
